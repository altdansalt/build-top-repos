# Bazel symlinks
/bazel-*
# Per-project run outputs (data; regenerated by `bazel run`)
/results/
# Automation: transcripts, the per-run result handoff, and the flock file
/automation/logs/
/automation/.result.json
/automation/.lock
# Python bytecode (would otherwise trip the orchestrator's clean-tree guard)
__pycache__/
*.pyc
